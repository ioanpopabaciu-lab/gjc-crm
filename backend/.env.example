# Backend Environment Variables
# Copiază acest fișier ca .env și completează valorile

# MongoDB Connection
MONGO_URL=mongodb://localhost:27017
DB_NAME=gjc_crm

# JWT Authentication (schimbă în producție!)
JWT_SECRET=GJC2026SecretKey-Change-In-Production

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Resend API pentru email notifications
# RESEND_API_KEY=re_xxxxxxxxxxxxx
